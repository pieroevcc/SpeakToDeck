# Copy this file to `.env` and fill in your own keys. Both are OPTIONAL.
#
# Transcription: with a key, audio goes to Groq's hosted Whisper (fast, ~zero
# RAM — required on small hosts like Streamlit Cloud). Without, transcription
# runs locally with faster-whisper. Free key: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# TTS: leave blank to use free edge-tts voices.
# Get a free NVIDIA key (prefixed nvapi-) at: https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=nvapi-...

# Sentence splitter override: set to "pysbd" on small hosts (the default "sat"
# neural splitter pulls in torch, ~1 GB RAM).
# SENTENCE_BACKEND=pysbd